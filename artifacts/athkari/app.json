{
  "expo": {
    "name": "أذكاري",
    "slug": "athkari",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "athkari",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A8A"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "السماح لأذكاري باستخدام موقعك لتحديد مواقيت الصلاة واتجاه القبلة بدقة."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.anaszyat.athkari"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "السماح لأذكاري باستخدام موقعك لتحديد مواقيت الصلاة واتجاه القبلة بدقة."
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "e702b45a-f06b-468d-980e-6b81079e7cb2"
      }
    },
    "owner": "anaszyat",
    "plugins": [
      ["react-native-google-mobile-ads", {"androidAppId": "ca-app-pub-6484709364382743~1638344904"}]
    ]
  }
}
